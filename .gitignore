__pycache__/
*.py[cod]
*.egg-info/
.venv/
.pytest_cache/
.ruff_cache/
.pyright/
dist/
build/

docs/**
# Re-include subdirectories so file-extension negations below can match.
# (Once a parent directory is ignored, gitignore cannot re-include its
#  contents — this rule keeps the directory tree visible.)
!docs/**/
!docs/**/*.tex
!docs/**/*.bib
!docs/**/*.md

.claude/*.local.*
.vscode